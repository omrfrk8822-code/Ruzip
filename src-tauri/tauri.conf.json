{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "RuZip",
  "version": "0.1.5",
  "identifier": "com.ruzip.desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "RuZip",
        "width": 1200,
        "height": 700,
        "minWidth": 1000,
        "minHeight": 500,
        "decorations": true,
        "center": true,
        "dragDropEnabled": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "wix": {
        "language": "tr-TR"
      }
    },
    "fileAssociations": [
      {
        "ext": ["zip"],
        "name": "ZIP Archive",
        "description": "ZIP Dosyası"
      }
    ]
  },
  "plugins": {}
}
